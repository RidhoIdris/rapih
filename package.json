{
  "name": "rapih",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "dev": "./scripts/dev.sh",
    "dev:api": "pnpm --filter @rapih/api dev",
    "dev:mobile": "pnpm --filter @rapih/mobile start",
    "dev:ios": "pnpm --filter @rapih/mobile ios",
    "dev:android": "pnpm --filter @rapih/mobile android",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "check": "turbo run check",
    "test": "turbo run test",
    "db:up": "docker compose -f infra/docker-compose.dev.yml up -d",
    "db:down": "docker compose -f infra/docker-compose.dev.yml down",
    "db:logs": "docker compose -f infra/docker-compose.dev.yml logs -f postgres",
    "db:psql": "docker exec -it rapih-postgres-dev psql -U rapih -d rapih",
    "db:migrate": "DATABASE_URL='postgresql://rapih:rapih@localhost:5433/rapih' pnpm --filter @rapih/db exec prisma migrate deploy",
    "db:migrate:test": "DATABASE_URL='postgresql://rapih:rapih@localhost:5433/rapih_test' pnpm --filter @rapih/db exec prisma migrate deploy",
    "mobile": "pnpm --filter @rapih/mobile",
    "mobile:dev": "pnpm --filter @rapih/mobile start",
    "mobile:android": "pnpm --filter @rapih/mobile android",
    "mobile:ios": "pnpm --filter @rapih/mobile ios",
    "mobile:web": "pnpm --filter @rapih/mobile web"
  },
  "devDependencies": {
    "eas-cli": "18.13.1",
    "turbo": "2.9.14"
  }
}
