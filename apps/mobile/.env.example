# Rapih Mobile — local-dev env

# API base URL.
# - iOS Simulator: http://localhost:3001 works.
# - Physical iPhone via dev build: replace with your Mac's LAN IP, e.g. http://192.168.1.100:3001
# - Production: https://api.rapih.app
EXPO_PUBLIC_API_URL=http://localhost:3001

# Google Sign-In Web Client ID (used as `webClientId` for ID token verification).
# This is the SAME ID used as `aud` claim by Google's ID token issuer.
# Backend validates `aud` against GOOGLE_OAUTH_CLIENT_IDS env on the API side.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=806008574126-jojh1etjr9ah0j4c3a68meaahclipnm4.apps.googleusercontent.com

# Google Sign-In iOS Client ID (used by GoogleSignin native SDK on iOS).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=806008574126-0car974hcp809kn5u92h0a3idi4jrufa.apps.googleusercontent.com
